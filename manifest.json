{
  "manifest_version": 3,
  "name": "RemindMeThat",
  "version": "0.1.0",
  "description": "Mind-wellness and productivity companion with reminders, mood tracking, journaling, and focus-friendly tools.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs",
    "activeTab",
    "scripting",
    "offscreen",
    "declarativeNetRequest",
    "webNavigation",
    "sidePanel",
    "idle"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "RemindMeThat",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "tracker-rules",
        "enabled": true,
        "path": "rules/tracker-rules.json"
      }
    ]
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
